{
  "name": "bullboard",
  "version": "0.0.0",
  "description": "A docker image for @bull-board",
  "keywords": [
    "bull",
    "bullmq",
    "dashboard",
    "docker",
    "monitoring",
    "queue",
    "redis"
  ],
  "bugs": {
    "url": "https://github.com/Venatum/bull-board-docker/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Vincent LE QUEC (Venatum)",
    "url": "https://github.com/Venatum"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Venatum/bull-board-docker.git"
  },
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node .",
    "start:dev": "nodemon .",
    "start:docker": "docker compose up --force-recreate --renew-anon-volumes --wait --detach",
    "start:docker-deps": "npm run start:docker redis",
    "stop:docker": "docker compose down -v",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt --write",
    "fix": "npm run lint:fix && npm run format:fix",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.7",
    "@bull-board/express": "^6.20.7",
    "body-parser": "^2.2.2",
    "bull": "^4.16.5",
    "bullmq": "^5.73.0",
    "connect-ensure-login": "^0.1.1",
    "dotenv": "^17.4.1",
    "exponential-backoff": "^3.1.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "ioredis": "^5.10.1",
    "morgan": "^1.10.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "nodemon": "^3.1.14",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "semantic-release": "^25.0.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "bun": "please use npm",
    "node": ">=24",
    "npm": ">=11",
    "pnpm": "please use npm",
    "yarn": "please use npm"
  }
}
